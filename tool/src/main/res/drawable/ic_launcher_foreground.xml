<?xml version="1.0" encoding="utf-8"?>
<!--
    Simplified, original game-controller silhouette with a clock face standing
    in for the action buttons - pairs "games" and "pastime" (Passatempo) into
    one mark. This is a generic gamepad shape, not modeled on any specific
    manufacturer's controller design. Stays within the adaptive icon's 66dp
    "safe zone" (worst-case corner distance ~32.8dp from center, under the
    33dp limit) so it isn't clipped by circular/rounded-square/squircle masks.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Controller body outline -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="4"
        android:pathData="M35,37 L73,37 A9,9 0 0 1 82,46 L82,62 A9,9 0 0 1 73,71 L35,71 A9,9 0 0 1 26,62 L26,46 A9,9 0 0 1 35,37 Z" />

    <!-- D-pad -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M34,51.5 L46,51.5 L46,56.5 L34,56.5 Z" />
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M37.5,48 L42.5,48 L42.5,60 L37.5,60 Z" />

    <!-- Clock face standing in for the action buttons -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="3"
        android:pathData="M59,54 A9,9 0 1 0 77,54 A9,9 0 1 0 59,54 Z" />
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:pathData="M68,54 L68,47" />
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:pathData="M68,54 L72.5,54" />

</vector>
